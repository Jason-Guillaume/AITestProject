# 本地开发环境变量示例（复制为 .env 即可生效）
# 注意：.env 已被 .gitignore 忽略，不会提交到仓库

# Django
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# MySQL（推荐创建专用账号而不是用 root）
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=ai_test_product
DB_USER=aitest
DB_PASSWORD=aitest

# Redis（可选；未启动会自动降级到本地内存 cache / channel layer）
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
USE_REDIS_CACHE=1

# AI 治理（可选）
AI_GUARD_DAILY_REQUESTS=0
AI_GUARD_MAX_CONCURRENCY=2
AI_GUARD_CONCURRENCY_TTL_SECONDS=180

# -------------------------------------------------------------------
# 知识中心（Knowledge Center / RAG）
# -------------------------------------------------------------------
# 单文件上传最大字节数（默认 10MB）
KNOWLEDGE_UPLOAD_MAX_SIZE=10485760

# URL 入库抓取超时（秒）与最大抓取字节数（默认 2MB）
KNOWLEDGE_URL_FETCH_TIMEOUT_SECONDS=15
KNOWLEDGE_URL_MAX_BYTES=2097152

# KnowledgeDocument 的 Chroma 本地持久化目录与集合名（可选）
# KNOWLEDGE_CHROMA_PERSIST_DIR=D:\\data\\chroma
KNOWLEDGE_CHROMA_COLLECTION=knowledge_documents

# Embedding 提供方（openai/ollama）。默认 openai；未配 OPENAI_API_KEY 会尝试降级 ollama。
KNOWLEDGE_EMBEDDING_PROVIDER=openai

# OpenAI（可选）
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
KNOWLEDGE_OPENAI_EMBED_MODEL=text-embedding-3-small

# Ollama（可选）
KNOWLEDGE_OLLAMA_BASE_URL=http://localhost:11434
KNOWLEDGE_OLLAMA_EMBED_MODEL=nomic-embed-text

